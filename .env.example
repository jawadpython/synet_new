# =============================================================================
# Firebase Admin (server — Vercel API routes)
# Use ONE of the two options below.
# =============================================================================

# Option A (recommended on Vercel): paste the full service account JSON on one line
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Option B: separate variables from the service account JSON file
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# =============================================================================
# Firebase Web (client — future admin dashboard only)
# From Firebase Console → Project settings → Your apps → Web app config
# =============================================================================
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=

# =============================================================================
# Optional — site URL for metadata (set in Vercel production)
# =============================================================================
# NEXT_PUBLIC_SITE_URL=https://www.synet.ma

# =============================================================================
# Admin bootstrap (npm run firebase:create-admin — do not commit real values)
# =============================================================================
# ADMIN_EMAIL=admin@synet.ma
# ADMIN_PASSWORD=YourSecurePassword1!
# ADMIN_NAME=SYNET Admin
